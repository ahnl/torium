---
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Tori.fi tekoälysi käyttöön. Selaa, hallitse ja vastaa Torin ilmoituksiin luonnollisella kielellä.',
  ogImage = '/og-image.png',
} = Astro.props;

const canonicalUrl = Astro.url.origin;
---
<!doctype html>
<html lang="fi">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:title" content={`${title} · Torium`} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={`${canonicalUrl}${ogImage}`} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={`${title} · Torium`} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={`${canonicalUrl}${ogImage}`} />
  <link rel="icon" type="image/png" href="/favicon.png" />
  <title>{title} · Torium</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Unbounded:wght@600&family=Inter:wght@400;500&family=JetBrains+Mono:wght@400&display=swap"
    rel="stylesheet"
  />
</head>
<body>
  <slot />
</body>
</html>

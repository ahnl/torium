---
import Layout from '../layouts/Layout.astro';
import DeleteForm from '../components/DeleteForm';
import Footer from '../components/Footer.astro';
---
<Layout title="Poista tietoni" description="Pyydä kaikkien toriumiin tallennettujen tietojesi poistamista">
  <div style="min-height: 100vh; display: flex; flex-direction: column;">
    <main style="flex: 1; max-width: 720px; margin: 0 auto; padding: 56px 24px 80px;">
      <a href="/" style="color: var(--torium-purple); text-decoration: none; font-size: 14px; font-weight: 500;">← Etusivulle</a>

      <h1 style="margin-top: 28px; margin-bottom: 10px;">Poista tietoni</h1>
      <p style="color: #666; margin-bottom: 36px; max-width: 520px; line-height: 1.6;">
        Syötä Tori.fi-kirjautumiseen käyttämäsi sähköpostiosoite. Lähetämme sinulle vahvistuslinkin,
        jonka klikkaaminen poistaa kaikki tietosi palvelimeltamme pysyvästi.
      </p>

      <DeleteForm client:load />
    </main>
    <Footer />
  </div>
</Layout>
